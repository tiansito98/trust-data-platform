# =============================================================================
# Streamlit Community Cloud secrets - copiar a .streamlit/secrets.toml
# =============================================================================
# Para deployment en Streamlit Cloud: pegar este contenido (con valores reales)
# en el editor de secrets del dashboard de Streamlit Cloud, NO commitearlo.
#
# Para desarrollo local: copia este archivo a .streamlit/secrets.toml. El
# archivo real ya esta en .gitignore.
# =============================================================================

# Connection string a Supabase Postgres (mismo formato que .env)
SUPABASE_DB_URL = "postgresql://postgres.example:CHANGE_ME@aws-0-region.pooler.supabase.com:5432/postgres"

# Auth simple: un solo usuario, credenciales que tu defines.
DASHBOARD_USER = "trust_admin"
DASHBOARD_PASS = "CHANGE_ME"
