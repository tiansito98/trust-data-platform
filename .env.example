# =============================================================================
# Trust Data Platform - variables de entorno
# =============================================================================
# 1. Copia este archivo a .env (sin el .example)
# 2. Llena los valores reales (los reales NO van en este template)
# 3. NUNCA committees .env (ya esta en .gitignore via .env / *.env)
#
# Contextos:
#   - Local: usa .env (este archivo es solo template)
#   - GitHub Actions: cada key se configura como repo secret y el workflow
#     la inyecta via `env:`
#   - Streamlit Cloud: las mismas keys van en .streamlit/secrets.toml (TOML)
#
# Resolucion unica: scripts/get_secret.py mira primero st.secrets, despues
# os.environ, despues .env.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase Postgres (target)
# -----------------------------------------------------------------------------
# Connection string completo desde Supabase: boton verde "Connect" (arriba
# derecha) -> tab "Direct" -> copia el "Session pooler" URI (puerto 5432).
# Reemplaza [YOUR-PASSWORD] con la contrasenia que pusiste al crear el
# proyecto.
SUPABASE_DB_URL=postgresql://postgres:CHANGE_ME@db.YOURPROJECT.supabase.co:5432/postgres


# -----------------------------------------------------------------------------
# SSH Tunnel hacia el bastion de Sixt (Redshift Data Exchange)
# -----------------------------------------------------------------------------
SIXT_SSH_HOST=CHANGE_ME.example.com
SIXT_SSH_PORT=22
SIXT_SSH_USER=CHANGE_ME

# Local: ruta absoluta al archivo de la llave privada PEM.
# GitHub Actions: NO uses path. Pon el CONTENIDO de la llave en el secret
# SIXT_SSH_PRIVATE_KEY; scripts/run_pipeline.py lo escribe a archivo temporal.
SIXT_SSH_KEY_PATH=
SIXT_SSH_PRIVATE_KEY=
SIXT_SSH_KEY_PASSPHRASE=


# -----------------------------------------------------------------------------
# Cluster Redshift Sixt (accedido a traves del tunel)
# -----------------------------------------------------------------------------
SIXT_REDSHIFT_HOST=CHANGE_ME.redshift.amazonaws.com
SIXT_REDSHIFT_PORT=5439
SIXT_REDSHIFT_DB=CHANGE_ME
SIXT_REDSHIFT_USER=CHANGE_ME
SIXT_REDSHIFT_PASSWORD=CHANGE_ME

# Puerto local que el tunel SSH expone (cualquier puerto libre).
LOCAL_PORT=8990


# -----------------------------------------------------------------------------
# Configuracion Trust
# -----------------------------------------------------------------------------
TRUST_MNDT_CODE=409
TRUST_OPRT_EMAIL=trust-operador@example.com


# -----------------------------------------------------------------------------
# Tuning del pipeline bronze
# -----------------------------------------------------------------------------
# Dias hacia atras al hacer el primer incremental (sin watermark previa).
BRONZE_INITIAL_LOOKBACK_DAYS=365
# Tamano de pagina al hacer paginated SELECT desde Redshift.
BRONZE_PAGE_SIZE=50000


# -----------------------------------------------------------------------------
# Dashboard auth (Streamlit)
# -----------------------------------------------------------------------------
# Credenciales hardcodeadas del UNICO usuario autorizado. Cambia AMBOS.
DASHBOARD_USER=trust_admin
DASHBOARD_PASS=CHANGE_ME
